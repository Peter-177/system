// ============================================================
// BACKUP: GamePage.jsx
// Date: 2026-03-20
// Description: Game Page - Team score tracking dashboard with 
//              admin controls for team and member management.
// ============================================================

import React, { useState } from "react";
import { Page, ModernNavbar, Avatar } from "../components/UI";
import { motion } from "framer-motion";
import { 
  Play, 
  Plus, 
  Users, 
  Trophy, 
  Gamepad2, 
  UserPlus, 
  ChevronLeft 
} from "lucide-react";

export function GamePage({ currentUser, onBack, onLogout, onGoHome, onGoClasses, onGoSearch, onGoSummer, onGoAdmin, onGoGame }) {
  const [teamA, setTeamA] = useState({
    name: "Team Alpha",
    score: 0,
    members: ["Peter", "John", "Mary"]
  });

  const [teamB, setTeamB] = useState({
    name: "Team Beta",
    score: 0,
    members: ["Sarah", "James", "Emma"]
  });

  const [isAdmin] = useState(currentUser?.role === "admin");

  const incrementScore = (team, amount) => {
    if (team === 'A') {
      setTeamA(prev => ({ ...prev, score: prev.score + amount }));
    } else {
      setTeamB(prev => ({ ...prev, score: prev.score + amount }));
    }
  };

  return (
    <Page noScrollLock={true} noFlex={true} noMinHeight={true}>
      <ModernNavbar 
        currentUser={currentUser} 
        onLogout={onLogout} 
        onGoHome={onGoHome} 
        onGoClasses={onGoClasses} 
        onGoSearch={onGoSearch}
        onGoAdmin={onGoAdmin}
        onGoSummer={onGoSummer}
        onGoGame={onGoGame}
        activePage="game"
      />

      <main className="px-8 sm:px-16 lg:px-24 pt-48 pb-40 max-w-7xl mx-auto w-full">
        {/* Header Section */}
        <header className="mb-20 flex flex-col md:flex-row justify-between items-end gap-8" dir="rtl">
          <motion.div 
            initial={{ opacity: 0, x: 30 }}
            animate={{ opacity: 1, x: 0 }}
            className="space-y-4"
          >
            <div className="flex items-center gap-4">
              <div className="h-0.5 w-12 bg-sky-500 rounded-full"></div>
              <span className="text-xs font-black uppercase tracking-[0.4em] text-sky-500/80">Arena Mode</span>
            </div>
            <h1 className="text-5xl font-black text-sky-50 tracking-tighter">صفحة الألعاب</h1>
            <p className="text-slate-500 font-bold max-w-md">تحدي المجموعات وجمع النقاط في جو من الحماس والروح الواحدة.</p>
          </motion.div>

          <button 
            onClick={onBack}
            className="group flex items-center gap-3 px-6 py-3 bg-slate-900/60 border border-white/5 rounded-2xl hover:border-sky-400/30 transition-all active:scale-95"
          >
             <span className="text-sm font-black text-sky-400 uppercase tracking-widest">Back</span>
             <ChevronLeft className="w-5 h-5 text-sky-400 group-hover:-translate-x-1 transition-transform" />
          </button>
        </header>

        {/* Teams Layout */}
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-12" dir="rtl">
          {/* Team A Card */}
          <TeamCard 
            team={teamA} 
            color="sky" 
            onIncrement={() => incrementScore('A', 1)} 
            isAdmin={isAdmin}
          />
          
          {/* Team B Card */}
          <TeamCard 
            team={teamB} 
            color="purple" 
            onIncrement={() => incrementScore('B', 1)} 
            isAdmin={isAdmin}
          />
        </div>

        {/* Global Controls */}
        <div className="mt-20 flex flex-col items-center gap-12">
          <div className="flex flex-wrap justify-center gap-6">
            <motion.button 
              whileHover={{ scale: 1.05 }}
              whileTap={{ scale: 0.95 }}
              className="px-12 py-6 bg-sky-500 text-slate-950 rounded-[2rem] font-black text-xl flex items-center gap-4 shadow-[0_0_40px_rgba(14,165,233,0.3)] group"
            >
              <Play className="fill-current w-6 h-6" />
              ابدأ اللعبة
            </motion.button>

            <motion.button 
              whileHover={{ scale: 1.05 }}
              whileTap={{ scale: 0.95 }}
              className="px-10 py-6 bg-slate-900 border border-white/10 text-sky-50 rounded-[2rem] font-black text-xl flex items-center gap-4 hover:border-sky-500/40 transition-all"
            >
              <Plus className="w-6 h-6 text-sky-400" />
              أضف لعبة جديدة
            </motion.button>
          </div>
          
          <p className="text-slate-500 font-black uppercase tracking-[0.6em] text-[10px] opacity-40">Battle System Active</p>
        </div>

        {/* Admin Section (Team Management) */}
        {isAdmin && (
          <motion.section 
            initial={{ opacity: 0, y: 40 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="mt-40 p-12 bg-slate-900/40 backdrop-blur-xl border border-white/5 rounded-[3rem] relative overflow-hidden"
            dir="rtl"
          >
            <div className="absolute top-0 right-0 w-64 h-64 bg-sky-500/5 blur-[100px] -mr-32 -mt-32"></div>
            
            <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-8">
              <div className="space-y-3 relative z-10">
                <div className="flex items-center gap-3">
                  <Gamepad2 className="text-sky-400 w-6 h-6" />
                  <h2 className="text-3xl font-black text-sky-50 tracking-tight">إدارة الفرق</h2>
                </div>
                <p className="text-slate-500 font-bold uppercase tracking-widest text-xs">Admin Team Management Console</p>
              </div>

              <button className="px-8 py-4 bg-slate-950 border border-white/10 text-sky-400 rounded-2xl font-black text-sm uppercase tracking-widest hover:border-sky-400/50 transition-all flex items-center gap-3 group">
                <Plus className="w-5 h-5 group-hover:rotate-90 transition-transform" />
                أضف فريق جديد
              </button>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-10">
              <AdminTeamList team={teamA} title="أعضاء الفريق الأول" />
              <AdminTeamList team={teamB} title="أعضاء الفريق الثاني" />
            </div>
          </motion.section>
        )}
      </main>
    </Page>
  );
}

function TeamCard({ team, color, onIncrement, isAdmin }) {
  const accentColor = color === 'sky' ? 'text-sky-400' : 'text-purple-400';
  const bgColor = color === 'sky' ? 'bg-sky-500/10' : 'bg-purple-500/10';
  const shadowColor = color === 'sky' ? 'shadow-sky-500/10' : 'shadow-purple-500/10';
  const borderColor = color === 'sky' ? 'group-hover:border-sky-500/30' : 'group-hover:border-purple-500/30';

  return (
    <motion.div 
      whileHover={{ y: -5 }}
      className={`group bg-slate-900/40 backdrop-blur-md p-10 rounded-[3rem] border border-white/5 ${borderColor} transition-all duration-500 shadow-2xl ${shadowColor} flex flex-col items-center text-center`}
    >
      <div className={`w-20 h-20 rounded-[2rem] ${bgColor} flex items-center justify-center ${accentColor} mb-8 border border-white/5`}>
        <Trophy className="w-10 h-10" />
      </div>

      <h3 className="text-2xl font-black text-slate-400 uppercase tracking-widest mb-2">{team.name}</h3>
      
      <div className="relative py-10">
        <motion.span 
          key={team.score}
          initial={{ scale: 0.8, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
          className={`text-9xl font-black tracking-tighter ${accentColor} drop-shadow-[0_0_30px_rgba(255,255,255,0.05)]`}
        >
          {team.score}
        </motion.span>
      </div>

      <div className="flex gap-4 mt-6">
        <button 
          onClick={onIncrement}
          className={`px-8 py-3 rounded-xl font-black text-sm uppercase tracking-widest transition-all active:scale-95 ${
            color === 'sky' ? 'bg-sky-500 text-slate-950' : 'bg-purple-500 text-white'
          }`}
        >
          +1 Point
        </button>
      </div>
      
      {/* Short List Preview */}
      <div className="mt-12 w-full pt-8 border-t border-white/5">
        <div className="flex items-center justify-center gap-2 mb-6">
          <Users className="w-4 h-4 text-slate-500" />
          <span className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em]">Team Members</span>
        </div>
        <div className="flex justify-center -space-x-3 space-x-reverse">
          {team.members.map((m, i) => (
            <div key={i} className="w-10 h-10 rounded-xl border-2 border-slate-900 overflow-hidden bg-slate-800 flex items-center justify-center">
              <span className="text-xs font-black text-sky-400">{m[0]}</span>
            </div>
          ))}
          <div className="w-10 h-10 rounded-xl border-2 border-slate-900 bg-slate-900 flex items-center justify-center">
            <Plus className="w-4 h-4 text-slate-500" />
          </div>
        </div>
      </div>
    </motion.div>
  );
}

function AdminTeamList({ team, title }) {
  return (
    <div className="space-y-6">
      <div className="flex justify-between items-center">
        <span className="text-sm font-black text-sky-50/60">{title}</span>
        <button className="p-2 bg-white/5 rounded-lg text-sky-400 hover:bg-sky-400/10 transition-colors">
          <UserPlus className="w-5 h-5" />
        </button>
      </div>
      <div className="space-y-3">
        {team.members.map((member, idx) => (
          <div key={idx} className="flex items-center justify-between p-4 bg-slate-950/40 border border-white/5 rounded-2xl group hover:border-sky-400/20 transition-all">
            <div className="flex items-center gap-4">
              <div className="w-10 h-10 rounded-xl bg-slate-900 border border-white/5 flex items-center justify-center text-sky-400 font-black text-sm uppercase group-hover:bg-sky-500 group-hover:text-slate-900 transition-all duration-500">
                {member[0]}
              </div>
              <span className="font-bold text-sky-50">{member}</span>
            </div>
            <div className="w-2 h-2 rounded-full bg-slate-800 group-hover:bg-sky-500 transition-colors"></div>
          </div>
        ))}
      </div>
    </div>
  );
}
